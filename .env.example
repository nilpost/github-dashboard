# GitHub Dashboard - Local Development Environment
# Copy this to .env and fill in your values:  cp .env.example .env
#
# Generate a SESSION_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# PostgreSQL connection string (local, Docker, or Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/github_dashboard

# Session encryption secret (32+ characters — replace the placeholder)
SESSION_SECRET=replace_with_generated_secret

# GitHub Personal Access Token (scopes: repo, read:user)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Environment (development enables the Vite dev server)
NODE_ENV=development

# Server port (default 5000 in dev)
PORT=5000

# Background sync interval in minutes (default 60)
SYNC_INTERVAL_MINUTES=60

# Logging level (default info)
LOG_LEVEL=info
