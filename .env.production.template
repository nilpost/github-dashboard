# GitHub Dashboard - Production Environment Template
# Copy this to .env.production (which is gitignored) and fill in real values.
#   cp .env.production.template .env.production
#
# Generate a SESSION_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/github_dashboard

# Session Security (replace with a 32+ byte random hex string — see command above)
SESSION_SECRET=replace_with_generated_secret

# GitHub API (scopes: repo, read:user)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Application
NODE_ENV=production
PORT=8000

# Background Jobs
SYNC_INTERVAL_MINUTES=60

# Logging
LOG_LEVEL=info
