{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node dist/index.js",
    "restartPolicyMaxRetries": 3
  },
  "env": {
    "NODE_ENV": "production",
    "PORT": "8000",
    "LOG_LEVEL": "info",
    "SYNC_INTERVAL_MINUTES": "60"
  },
  "plugins": [
    {
      "name": "postgresql"
    }
  ]
}
